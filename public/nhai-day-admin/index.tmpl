      <span style="color:var(--textM)">Trạng thái:</span>
      <label style="display:flex;align-items:center;gap:4px;cursor:pointer;color:var(--teal)"><input type="radio" name="ir_s" value="announced" checked/> Công bố ngay</label>
      <label style="display:flex;align-items:center;gap:4px;cursor:pointer"><input type="radio" name="ir_s" value="pending"/> Lưu nháp</label>
