async function publishAllDrafts(){
  const drafts=state.cases.filter(c=>!c.is_active&&c.season_id===state.currentSeason);
  for(const d of drafts)await sb(`cases?id=eq.${d.id}`,{method:"PATCH",body:{is_active:true}});
  toast(`Đã publish ${drafts.length} cases`);loadAll();
}

async function importSubmissionsFromSheet(){
  const url=getUrl("submissions");
  if(!url){toast("Chưa có gid","danger");return;}
  toast("Đang fetch sheet submissions...");
  try{
    const res=await fetch(url);
    if(!res.ok)throw new Error("Fetch failed — đã publish sheet chưa?");
    const rows=parseCSV(await res.text());
    if(rows.length<2){toast("Sheet trống","danger");return;}
    const headers=rows[0];
    const findCol=(kws)=>headers.findIndex(h=>kws.some(k=>h.toLowerCase().includes(k.toLowerCase())));
    const emailCol=findCol(["email"]);
    const titleCol=findCol(["tên case","case","title"]);
    const cityCol=findCol(["đâu","city","thành phố","nhai day tại"]);
    const descCol=findCol(["mô tả","description","ngắn gọn"]);
    const demoCol=findCol(["demo","file","link","sản phẩm"]);
    const existingEmails=new Set(state.cases.map(c=>c.owner_email).filter(Boolean));
    const parsed=[];
    for(const row of rows.slice(1)){
      const email=(emailCol>=0?row[emailCol]:"")||"";
      if(!email||!email.includes("@")||existingEmails.has(email))continue;
      const title=(titleCol>=0?row[titleCol]:"")||"";
      const cityRaw=(cityCol>=0?row[cityCol]:"")||"";
      const desc=(descCol>=0?row[descCol]:"")||"";
      const demo=(demoCol>=0?row[demoCol]:"")||"";
      if(!title.trim())continue;
      const city=cityRaw.includes("Hồ Chí Minh")||cityRaw.includes("HCM")?"Hồ Chí Minh":"Hà Nội";
      parsed.push({email,title:title.slice(0,120),city,desc:desc.slice(0,200),demo});
    }
    if(!parsed.length){toast(`Không có case mới (${rows.length-1} rows đã import hết)`);return;}
    // Auto import all as draft
    let n=0;
    for(const p of parsed){
      const id=(p.city==="Hà Nội"?"hn":"hcm")+"-auto-"+Date.now()+"-"+(n++);
      await sb("cases",{method:"POST",body:{id,title:p.title,city:p.city,sticker:"🤖",owner_email:p.email,owner_name:p.email.split("@")[0],short_description:p.desc,demo_url:p.demo,tools_used:[],season_id:state.currentSeason,display_order:state.cases.length+n,is_active:false},headers:{Prefer:"return=representation"}});
    }
    toast(`Đã import ${n} cases mới (draft)`);loadAll();
  }catch(e){toast("Lỗi: "+e.message,"danger");}
}

