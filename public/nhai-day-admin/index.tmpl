let regFilter={season:'current',city:'all',team:'all',search:'',sort:'created_at',sortDir:'desc'};

function exportRegCSV(all){
  const regs=all?state.registrations:getFilteredRegs();
  if(!regs.length){toast("Không có dữ liệu để export","danger");return;}
  const cols=["season_id","full_name","email","city","team","registration_type","member2_name","member2_email","member2_team","member3_name","member3_email","member3_team","problem_to_solve","team_matching_note","ai_level","expected_output","created_at"];
  const header=cols.join(",");
  const rows=regs.map(r=>cols.map(c=>{
    const v=r[c]||"";
    return typeof v==="string"&&(v.includes(",")||v.includes('"')||v.includes("\n"))
      ?'"'+v.replace(/"/g,'""')+'"' : v;
  }).join(","));
  const csv=[header,...rows].join("\n");
  const blob=new Blob(["﻿"+csv],{type:"text/csv;charset=utf-8"});
  const url=URL.createObjectURL(blob);
  const a=document.createElement("a");
  a.href=url;a.download=(all?"all_registrations":"registrations_filtered")+".csv";
  a.click();URL.revokeObjectURL(url);
  toast("Đã export "+regs.length+" bản ghi!");
}

function getFilteredRegs(){
  let regs=state.registrations;
  if(regFilter.season==='current')regs=regs.filter(r=>r.season_id===state.currentSeason);
  else if(regFilter.season!=='all')regs=regs.filter(r=>r.season_id===regFilter.season);
  if(regFilter.city!=='all')regs=regs.filter(r=>r.city===regFilter.city);
  if(regFilter.team!=='all')regs=regs.filter(r=>r.team===regFilter.team);
  if(regFilter.search){
    const q=regFilter.search.toLowerCase();
    regs=regs.filter(r=>(r.full_name||'').toLowerCase().includes(q)||(r.email||'').toLowerCase().includes(q)||(r.member2_name||'').toLowerCase().includes(q)||(r.member3_name||'').toLowerCase().includes(q)||(r.problem_to_solve||'').toLowerCase().includes(q));
  }
  const s=regFilter.sort,d=regFilter.sortDir==='asc'?1:-1;
  regs.sort((a,b)=>{const va=a[s]||'',vb=b[s]||'';return va<vb?-d:va>vb?d:0;});
  return regs;
}

function setRegFilter(k,v){regFilter[k]=v;render();}
function toggleRegSort(col){
  if(regFilter.sort===col)regFilter.sortDir=regFilter.sortDir==='asc'?'desc':'asc';
  else{regFilter.sort=col;regFilter.sortDir='desc';}
  render();
}

async function deleteReg(id){
