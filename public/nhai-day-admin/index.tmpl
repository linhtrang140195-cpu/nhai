async function moveEvent(id,dir){
  const evs=[...state.events].sort((a,b)=>(a.display_order||0)-(b.display_order||0));
  const idx=evs.findIndex(e=>e.id===id);
  if(idx<0)return;
  const swapIdx=idx+dir;
  if(swapIdx<0||swapIdx>=evs.length)return;
  const a=evs[idx],b=evs[swapIdx];
  const ao=a.display_order??idx+1, bo=b.display_order??swapIdx+1;
  await Promise.all([
    sb(`events?id=eq.${a.id}`,{method:"PATCH",body:{display_order:bo}}),
    sb(`events?id=eq.${b.id}`,{method:"PATCH",body:{display_order:ao}})
  ]);
  loadAll();
}

