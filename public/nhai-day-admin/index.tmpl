    if(r.member3_name&&r.member3_name.trim()){const t3=r.member3_team||t;teamCounts[t3]=(teamCounts[t3]||0)+1;}
  });
  const sorted=Object.entries(teamCounts).sort((a,b)=>b[1]-a[1]);
