async function calcFeedbackStats(){
  const url=getUrl("feedback");
  if(!url){toast("Chưa có gid feedback","danger");return;}
  toast("Đang fetch form đánh giá...");
  try{
    const res=await fetch(url);
    if(!res.ok)throw new Error("Fetch failed");
    const rows=parseCSV(await res.text());
    if(rows.length<2){toast("Sheet trống","danger");return;}
    const headers=rows[0];
    const findCol=(kws)=>headers.findIndex(h=>kws.some(k=>h.toLowerCase().includes(k.toLowerCase())));
    const cityCol=findCol(["đâu","city","khu vực"]);
    const expCol=findCol(["tổng thể","trải nghiệm","diem trai nghiem","overall"]);
    const mentorCol=findCol(["hữu ích","mentor","diem huu ich"]);
    const demoCol=findCol(["output","demo","hoàn thiện"]);
    const continueCol=findCol(["tiếp tục phát triển","muon tiep tuc"]);

    // Filter: từ ngày HN → ngày HCM + 5 ngày
    const seasonEvents=state.events.filter(e=>e.season_id===state.currentSeason&&e.date);
    const hnEvent=seasonEvents.find(e=>e.city==="Hà Nội");
    const hcmEvent=seasonEvents.find(e=>e.city==="Hồ Chí Minh"||e.city==="TP.HCM");
    const startDate=hnEvent?new Date(hnEvent.date):null;
    const endDate=hcmEvent?new Date(new Date(hcmEvent.date).getTime()+5*24*3600*1000):startDate?new Date(startDate.getTime()+10*24*3600*1000):null;

    const filtered=rows.slice(1).filter(row=>{
      const ts=row[0]?new Date(row[0]):null;
      if(!ts||isNaN(ts))return false;
      if(startDate&&ts<startDate)return false;
      if(endDate&&ts>endDate)return false;
      return true;
    });

    if(!filtered.length){toast("Không có response nào trong khoảng thời gian mùa này","danger");return;}
    const expScores=filtered.map(r=>parseFloat(expCol>=0?r[expCol]:0)).filter(n=>!isNaN(n)&&n>0);
    const mentorScores=filtered.map(r=>parseFloat(mentorCol>=0?r[mentorCol]:0)).filter(n=>!isNaN(n)&&n>0);
    const hasDemo=filtered.filter(r=>demoCol>=0&&/demo|được|có/i.test(r[demoCol]||"")).length;
    const wantContinue=filtered.filter(r=>continueCol>=0&&/chắc|có/i.test(r[continueCol]||"")).length;
    const avgExp=expScores.length?+(expScores.reduce((a,b)=>a+b,0)/expScores.length).toFixed(2):0;
    const avgMentor=mentorScores.length?+(mentorScores.reduce((a,b)=>a+b,0)/mentorScores.length).toFixed(2):0;
    const pctDemo=+(hasDemo/filtered.length*100).toFixed(1);
    const pctContinue=+(wantContinue/filtered.length*100).toFixed(1);
    // Save to season_stats
    await sb(`season_stats?season_id=eq.${state.currentSeason}`,{method:"PATCH",body:{avg_experience:avgExp,avg_mentor:avgMentor,pct_has_demo:pctDemo,pct_want_continue:pctContinue,feedback_count:filtered.length,updated_at:new Date().toISOString()}});
    toast(`Đã tính: exp ${avgExp}★, mentor ${avgMentor}★, ${pctContinue}% tiếp tục`);
    loadAll();
  }catch(e){toast("Lỗi: "+e.message,"danger");}
}

