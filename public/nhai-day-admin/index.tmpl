<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NHAI DAY Admin</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
:root{
--bg:#0A0E1A;--bg2:#131826;--bg3:#1A2035;
--border:rgba(255,255,255,0.06);--borderL:rgba(255,255,255,0.1);
--gold:#F5C842;--goldD:#E8A317;--goldBg:rgba(245,200,66,0.08);--goldBd:rgba(245,200,66,0.2);
--pink:#EC4899;--pinkBg:rgba(236,72,153,0.12);--pinkT:#F9A8D4;
--teal:#14B8A6;--tealBg:rgba(20,184,166,0.12);--tealT:#5EEAD4;
--purple:#A78BFA;--purpleBg:rgba(167,139,250,0.12);
--text:#F5F7FA;--textS:#C4CBD9;--textM:#8B92A5;
--danger:#EF4444;--dangerBg:rgba(239,68,68,0.12);
}
body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--text);font-size:13px;overflow:hidden;height:100vh}
.shell{display:flex;height:100vh}
.sidebar{width:210px;background:var(--bg2);border-right:1px solid var(--border);padding:16px 0;flex-shrink:0;overflow-y:auto}
.logo{padding:0 16px 14px;border-bottom:1px solid var(--border);margin-bottom:8px;display:flex;align-items:center;gap:10px}
.logo-icon{width:34px;height:34px;border-radius:8px;background:linear-gradient(135deg,var(--gold),var(--goldD));display:flex;align-items:center;justify-content:center;font-size:16px;box-shadow:0 0 20px rgba(245,200,66,0.3)}
.logo-text{font-size:13px;font-weight:600}.logo-text span{color:var(--gold)}
.logo-sub{font-size:9px;color:var(--textM);letter-spacing:0.5px}
.nav-sec{font-size:9px;text-transform:uppercase;color:var(--textM);padding:12px 16px 4px;letter-spacing:1.2px;font-weight:600}
.nav-item{display:flex;align-items:center;gap:8px;padding:8px 16px;font-size:12px;color:var(--textS);cursor:pointer;border-left:2px solid transparent;transition:all .15s}
.nav-item:hover{background:var(--bg3)}
.nav-item.active{color:var(--gold);background:var(--goldBg);border-left-color:var(--gold);font-weight:600}
.main{flex:1;display:flex;flex-direction:column;overflow:hidden}
.topbar{padding:12px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--bg2);flex-shrink:0}
.topbar-title{font-size:15px;font-weight:600}
.content{flex:1;overflow-y:auto;padding:20px}
.btn{font-size:11px;padding:5px 11px;border:1px solid var(--borderL);border-radius:8px;background:none;color:var(--textS);cursor:pointer;display:inline-flex;align-items:center;gap:5px;font-weight:500;font-family:inherit;transition:all .15s}
.btn:hover{background:var(--bg3)}
.btn-primary{background:var(--gold)!important;color:#1A1F2E!important;border:none!important}
.btn-success{background:var(--teal)!important;color:white!important;border:none!important}
.btn-danger{background:var(--danger)!important;color:white!important;border:none!important}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:14px}
.card-header{padding:12px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap}
.card-title{font-size:13px;font-weight:500}
.card-sub{font-size:11px;color:var(--textM);margin-top:2px}
.stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px}
.stat{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:14px;position:relative;overflow:hidden}
.stat-bar{position:absolute;top:0;left:0;width:3px;height:100%}
.stat-num{font-size:24px;font-weight:600;letter-spacing:-.5px;font-family:'JetBrains Mono',monospace}
.stat-label{font-size:10px;color:var(--textM);text-transform:uppercase;letter-spacing:.8px;margin-top:3px}
.stat-sub{font-size:10px;color:var(--teal);margin-top:6px}
.badge{font-size:10px;padding:2px 8px;border-radius:99px;font-weight:600;white-space:nowrap;display:inline-block}
.badge-gold{background:var(--goldBg);color:var(--gold);border:1px solid var(--goldBd)}
.badge-hn{background:var(--pinkBg);color:var(--pinkT)}
.badge-hcm{background:var(--tealBg);color:var(--tealT)}
.badge-success{background:rgba(20,184,166,0.15);color:var(--tealT)}
.badge-danger{background:var(--dangerBg);color:#FCA5A5}
.badge-muted{background:rgba(255,255,255,0.05);color:var(--textM);border:1px solid var(--border)}
.list-row{display:flex;align-items:center;gap:10px;padding:10px 16px;border-bottom:1px solid var(--border);transition:background .1s}
.list-row:hover{background:var(--bg3)}
.list-row:last-child{border-bottom:none}
.city-tabs{display:flex;gap:6px;margin-bottom:14px}
.city-tab{padding:6px 14px;border-radius:99px;font-size:11px;font-weight:500;cursor:pointer;border:1px solid var(--borderL);color:var(--textM);transition:all .15s}
.city-tab.active-all{background:var(--goldBg);color:var(--gold);border-color:var(--goldBd)}
.city-tab.active-hn{background:var(--pinkBg);color:var(--pinkT);border-color:transparent}
.city-tab.active-hcm{background:var(--tealBg);color:var(--tealT);border-color:transparent}
.two-col-city{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.city-section{border-radius:10px;overflow:hidden;border:1px solid var(--border)}
.city-header-hn{padding:8px 12px;background:var(--pinkBg);font-size:11px;font-weight:600;color:var(--pinkT);display:flex;align-items:center;gap:6px}
.city-header-hcm{padding:8px 12px;background:var(--tealBg);font-size:11px;font-weight:600;color:var(--tealT);display:flex;align-items:center;gap:6px}
.rank{width:26px;height:26px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;font-family:'JetBrains Mono',monospace;flex-shrink:0}
.rank-1{background:linear-gradient(135deg,var(--gold),var(--goldD));color:#1A1F2E}
.rank-2{background:linear-gradient(135deg,#E5E7EB,#B4B2A9);color:#1A1F2E}
.rank-3{background:linear-gradient(135deg,#D97757,#B24E2E);color:#FEF3F2}
.rank-n{background:rgba(255,255,255,0.04);color:var(--textM);border:1px solid var(--borderL)}
.sticker{width:34px;height:34px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;background:linear-gradient(135deg,var(--purple),#7C3AED)}
.votes-num{font-family:'JetBrains Mono',monospace;font-size:15px;font-weight:600;color:var(--gold)}
.votes-lbl{font-size:9px;color:var(--textM)}
.toggle{width:40px;height:22px;border-radius:11px;cursor:pointer;position:relative;transition:all .2s;flex-shrink:0}
.toggle.on{background:var(--teal)}.toggle.off{background:rgba(255,255,255,0.1)}
.toggle-knob{width:16px;height:16px;border-radius:50%;background:white;position:absolute;top:3px;transition:all .2s}
.toggle.on .toggle-knob{left:21px}.toggle.off .toggle-knob{left:3px}
.mentor-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;padding:14px}
.mentor-card{background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:12px;text-align:center;cursor:pointer;transition:border-color .15s}
.mentor-card:hover{border-color:var(--goldBd)}
.mentor-avatar{width:42px;height:42px;border-radius:50%;background:var(--purpleBg);margin:0 auto 8px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;color:var(--purple)}
.award-two-col{display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:14px}
.award-card{background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:12px;transition:border-color .15s}
.award-card.filled{border-color:var(--goldBd)}
.early-list{padding:0}
.early-item{display:flex;align-items:center;gap:8px;padding:8px 12px;border-bottom:1px solid var(--border);font-size:11px}
.early-item:last-child{border-bottom:none}
textarea,input[type=text],input[type=email],input[type=date],input[type=number],input[type=file],select{
width:100%;font-size:13px;padding:8px 10px;border:1px solid var(--borderL);border-radius:8px;
background:var(--bg);color:var(--text);outline:none;font-family:inherit;margin-bottom:10px}
textarea{resize:vertical;min-height:60px}
label{font-size:11px;color:var(--textM);display:block;margin-bottom:4px}
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:999;display:flex;align-items:center;justify-content:center;padding:20px}
.modal{background:var(--bg2);border:1px solid var(--borderL);border-radius:14px;width:460px;max-height:85vh;overflow:auto;padding:20px}
.modal-title{font-size:15px;font-weight:600;margin-bottom:16px}
.modal-actions{display:flex;gap:8px;justify-content:flex-end;margin-top:16px}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.toast{position:fixed;top:16px;right:16px;z-index:9999;padding:10px 16px;border-radius:10px;font-size:12px;font-weight:500;color:white;box-shadow:0 8px 24px rgba(0,0,0,0.4);animation:fadeIn .3s}
.empty-state{padding:30px;text-align:center;color:var(--textM);font-size:12px}
@keyframes fadeIn{from{opacity:0;transform:translateY(-10px)}to{opacity:1;transform:translateY(0)}}
#gate{position:fixed;inset:0;background:var(--bg);display:flex;align-items:center;justify-content:center;z-index:9999}
#gate.hidden{display:none}
.gate-box{background:var(--bg2);border:1px solid var(--border);border-radius:16px;padding:36px 32px;width:340px;text-align:center}
.gate-box h2{font-size:18px;font-weight:700;margin-bottom:4px}
.gate-box p{font-size:12px;color:var(--textM);margin-bottom:20px}
.gate-inp{width:100%;padding:10px 14px;border-radius:8px;border:1px solid var(--border);background:var(--bg3);color:var(--text);font-size:14px;outline:none;margin-bottom:10px}
.gate-inp:focus{border-color:var(--gold)}
.gate-btn{width:100%;padding:10px;border-radius:8px;border:none;background:var(--gold);color:#0A0E1A;font-weight:700;font-size:14px;cursor:pointer}
.gate-err{color:var(--danger);font-size:12px;margin-top:8px;display:none}
</style>
</head>
<body>
<div id="gate">
  <div class="gate-box">
    <h2>🔐 NHAI DAY Admin</h2>
    <p>Nhập mật khẩu để tiếp tục</p>
    <input class="gate-inp" id="gatePwd" type="password" placeholder="Mật khẩu" onkeydown="if(event.key==='Enter')checkGate()">
    <button class="gate-btn" onclick="checkGate()">Đăng nhập</button>
    <div class="gate-err" id="gateErr">Mật khẩu không đúng</div>
  </div>
</div>
<script>
(function(){
  if(sessionStorage.getItem('nhai_admin_ok')==='1') document.getElementById('gate').classList.add('hidden');
})();
function checkGate(){
  const v=document.getElementById('gatePwd').value;
  if(v==='nhainhai2026'){sessionStorage.setItem('nhai_admin_ok','1');document.getElementById('gate').classList.add('hidden');}
  else{const e=document.getElementById('gateErr');e.style.display='block';setTimeout(()=>e.style.display='none',2000);}
}
</script>
<div class="shell">
  <div class="sidebar" id="sidebar"></div>
  <div class="main">
    <div class="topbar">
      <div class="topbar-title" id="topTitle">Dashboard</div>
      <div style="display:flex;gap:8px;align-items:center">
        <div id="seasonPick" onclick="cycleSeason()" style="display:flex;align-items:center;gap:8px;font-size:12px;padding:5px 12px;border:1px solid var(--goldBd);border-radius:8px;background:var(--goldBg);color:var(--gold);cursor:pointer;font-weight:500">📅 — ▾</div>
        <button class="btn" onclick="loadAll()" style="font-size:11px">🔄 Refresh</button>
      </div>
    </div>
    <div class="content" id="content"></div>
  </div>
</div>
<div id="toastArea"></div>
<div id="modalArea"></div>

<script>
const SB_URL = ""; // same-origin — served by our own Express API now (was Supabase)
const SB_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhtdHhkZmVlbmdwYmFwZ3VkcHJ4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM2MDg0MTAsImV4cCI6MjA5OTE4NDQxMH0.NNePCWoFDuRWmeDI01FK5XOF9IbQq4E3H6wJEju-tRY";

const SHEETS = {
  results: "https://docs.google.com/spreadsheets/d/1bi225gwc4xVayNXquit7U7GiSXBloBEt/export?format=csv",
  submissions: "https://docs.google.com/spreadsheets/d/1YPwpx9Kz5rnFk1cZlkHms4BBZC-EVXJmN5g4bIzNaOM/export?format=csv",
  feedback: "https://docs.google.com/spreadsheets/d/1Nv0-uVvwffgjMA7PiKOz7tETaafNaYmo7q6lWS3CBVw/export?format=csv"
};

let seasonGids = JSON.parse(localStorage.getItem("nhai_gids") || JSON.stringify({
  "nhai-day-01": {results:"1648087017", submissions:"1165794480", feedback:"251297283"},
  "nhai-day-02": {results:"", submissions:"", feedback:""},
  "nhai-day-03": {results:"", submissions:"", feedback:""},
  "nhai-day-04": {results:"", submissions:"", feedback:""}
}));
function saveGids(){localStorage.setItem("nhai_gids",JSON.stringify(seasonGids));}
function getUrl(type){const g=seasonGids[state.currentSeason]?.[type];return g?`${SHEETS[type]}&gid=${g}`:null;}

let state={tab:"dashboard",seasons:[],events:[],mentors:[],faqs:[],registrations:[],awards:[],awardCats:[],cases:[],config:{},campaigns:[],votes:[],seasonStats:[],currentSeason:"nhai-day-01",loading:true,cityFilter:"all"};

async function sb(path,opts={}){
  try{
    const res=await fetch(`${SB_URL}/rest/v1/${path}`,{
      headers:{apikey:SB_KEY,Authorization:`Bearer ${SB_KEY}`,"Content-Type":"application/json",Prefer:opts.prefer||"return=representation",...opts.headers},
      method:opts.method||"GET",body:opts.body?JSON.stringify(opts.body):undefined
    });
    if(!res.ok){console.error("SB error:",res.status,await res.text());return[];}
    const t=await res.text();return t?JSON.parse(t):[];
  }catch(e){console.error(e);return[];}
}

async function loadAll(){
  state.loading=true;render();
  const[s,e,m,f,r,a,ac,c,cfg,camp,v,ss]=await Promise.all([
    sb("seasons?order=display_order"),sb("events?order=display_order"),
    sb("mentors?order=display_order"),sb("faqs?order=display_order"),
    sb("registrations?order=created_at.desc&limit=5000"),sb("awards?order=created_at"),
    sb("award_categories?order=display_order"),sb("cases?order=display_order"),
    sb("site_config"),sb("top_pick_campaigns?order=created_at"),
    sb("top_pick_votes?order=created_at.desc&limit=100"),
    sb("season_stats?order=season_id").catch(()=>[])
  ]);
  state.seasons=s;state.events=e;state.mentors=m;state.faqs=f;
  state.registrations=r;state.awards=a;state.awardCats=ac;state.cases=c;
  state.campaigns=camp;state.votes=v;state.seasonStats=ss||[];
  const cfg2={};(cfg||[]).forEach(row=>{try{cfg2[row.key]=row.value}catch{}});state.config=cfg2;
  if(s.length&&!s.find(x=>x.id===state.currentSeason))state.currentSeason=s[0].id;
  state.loading=false;render();
  autoBackupToSheet();
}

function toast(msg,type="success"){
  document.getElementById("toastArea").innerHTML=`<div class="toast" style="background:${type==="danger"?"var(--danger)":"var(--teal)"}">${msg}</div>`;
  setTimeout(()=>document.getElementById("toastArea").innerHTML="",3000);
}

function cycleSeason(){
  const idx=state.seasons.findIndex(s=>s.id===state.currentSeason);
  const next=state.seasons[(idx+1)%state.seasons.length];
  if(next){state.currentSeason=next.id;state.cityFilter="all";render();}
}

function setTab(t){state.tab=t;render();}
function setCityFilter(f){state.cityFilter=f;render();}
function closeModal(){document.getElementById("modalArea").innerHTML="";}
function getField(k){return document.getElementById("f_"+k)?.value||"";}

async function saveConfig(key,value){
  await sb(`site_config?key=eq.${key}`,{method:"PATCH",body:{value:JSON.stringify(value),updated_at:new Date().toISOString()}});
  state.config[key]=value;toast(`Đã lưu ${key}`);render();
}

async function upsert(table,data,id){
  if(id)await sb(`${table}?id=eq.${id}`,{method:"PATCH",body:data});
  else await sb(table,{method:"POST",body:data,headers:{Prefer:"return=representation"}});
  toast("Đã lưu!");closeModal();loadAll();
}

async function deleteItem(table,id){
  if(!confirm("Xóa?"))return;
  await sb(`${table}?id=eq.${id}`,{method:"DELETE"});
  toast("Đã xóa!","danger");loadAll();
}

async function toggleCaseActive(id,cur){
  await sb(`cases?id=eq.${id}`,{method:"PATCH",body:{is_active:!cur}});
  toast(!cur?"Case published!":"Case ẩn");loadAll();
}

// CSV parser
function parseCSV(text){
  const rows=[];let row=[];let cell="";let inQ=false;
  for(let i=0;i<text.length;i++){
    const ch=text[i];
    if(inQ){if(ch==='"'&&text[i+1]==='"'){cell+='"';i++;}else if(ch==='"')inQ=false;else cell+=ch;}
    else{if(ch==='"')inQ=true;else if(ch===','){row.push(cell.trim());cell="";}
    else if(ch==='\n'||(ch==='\r'&&text[i+1]==='\n')){row.push(cell.trim());cell="";if(row.some(c=>c))rows.push(row);row=[];if(ch==='\r')i++;}
    else cell+=ch;}
  }
  if(cell||row.length){row.push(cell.trim());if(row.some(c=>c))rows.push(row);}
  return rows;
}

// ===== RENDER =====
function render(){
  renderSidebar();
  const labels={dashboard:"Dashboard",analytics:"Analytics",schedule:"Lịch trình",results:"Kết quả",voting:"Voting",audit:"Vote audit",registrations:"Đăng ký tham gia",mentors:"Mentors",faq:"FAQ",media:"Ảnh và Media",settings:"Cài đặt site"};
  document.getElementById("topTitle").textContent=labels[state.tab]||"Dashboard";
  const s=state.seasons.find(x=>x.id===state.currentSeason);
  document.getElementById("seasonPick").textContent=`📅 ${s?s.name:"—"} ▾`;
  if(state.loading){document.getElementById("content").innerHTML=`<div class="empty-state"><div style="font-size:28px;margin-bottom:12px">🍜</div>Đang load...</div>`;return;}
  const fn={dashboard:renderDashboard,analytics:renderAnalytics,schedule:renderSchedule,results:renderResults,voting:renderVoting,audit:renderAudit,registrations:renderRegistrations,mentors:renderMentors,faq:renderFAQ,media:renderMedia,settings:renderSettings};
  document.getElementById("content").innerHTML=(fn[state.tab]||renderDashboard)();
}

function renderSidebar(){
  const nav=[
    {sec:"Tổng quan"},{id:"dashboard",icon:"📊",label:"Dashboard"},{id:"analytics",icon:"📈",label:"Analytics"},
    {sec:"Nội dung mùa"},{id:"schedule",icon:"📅",label:"Lịch trình"},{id:"results",icon:"🏆",label:"Kết quả"},
    {id:"voting",icon:"❤️",label:"Voting"},{id:"audit",icon:"🛡️",label:"Vote audit"},
    {sec:"Danh sách"},{id:"registrations",icon:"👥",label:"Đăng ký tham gia"},{id:"mentors",icon:"⭐",label:"Mentors"},{id:"faq",icon:"❓",label:"FAQ"},
    {sec:"Cấu hình"},{id:"media",icon:"🖼️",label:"Ảnh và Media"},{id:"settings",icon:"⚙️",label:"Cài đặt site"}
  ];
  let h=`<div class="logo"><div class="logo-icon">🍜</div><div><div class="logo-text">NHAI DAY <span>Admin</span></div><div class="logo-sub">NÊM AI VÀO CÔNG VIỆC</div></div></div>`;
  nav.forEach(n=>{
    if(n.sec)h+=`<div class="nav-sec">${n.sec}</div>`;
    else h+=`<div class="nav-item ${state.tab===n.id?"active":""}" onclick="setTab('${n.id}')">${n.icon} ${n.label}</div>`;
  });
  document.getElementById("sidebar").innerHTML=h;
}

function renderDashboard(){
  const s=state.seasons.find(x=>x.id===state.currentSeason);
  const ss=state.seasonStats.find(x=>x.season_id===state.currentSeason)||{};
  const totalAllSeasons=state.seasonStats.reduce((a,b)=>a+(b.total_participants||0),0);
  const seasonRegs=state.registrations.filter(r=>r.season_id===state.currentSeason);
  const headcount=seasonRegs.length + seasonRegs.filter(r=>r.member2_name&&r.member2_name.trim()).length + seasonRegs.filter(r=>r.member3_name&&r.member3_name.trim()).length;
  return `
  <div style="background:linear-gradient(135deg,var(--goldBg),rgba(217,90,48,0.04));border:1px solid var(--goldBd);border-radius:14px;padding:16px 20px;display:flex;align-items:center;gap:16px;margin-bottom:16px">
    <div style="width:44px;height:44px;border-radius:12px;background:rgba(245,200,66,0.15);border:1px solid var(--goldBd);display:flex;align-items:center;justify-content:center;font-size:20px">🍜</div>
    <div style="flex:1"><div style="font-size:10px;text-transform:uppercase;letter-spacing:1.5px;color:var(--gold);font-weight:600;margin-bottom:4px">Đang quản lý</div>
    <div style="font-size:17px;font-weight:600">${s?s.name:"NHAI DAY"} · Admin Panel</div></div>
