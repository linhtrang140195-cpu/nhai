    <div class="modal-actions">
      <button class="btn" onclick="closeModal()">Hủy</button>
      <button class="btn btn-primary" onclick="upsert('awards',{season_id:'${state.currentSeason}',category_id:getField('cat'),city:getField('city')||null,winner_name:getField('wname'),winner_team:getField('wteam'),votes_count:parseInt(getField('votes'))||0,status:getField('status')},'${awardId||""}')">Lưu</button>
    </div>
  </div></div>`;
}

function openCaseModal(){
  document.getElementById("modalArea").innerHTML=`
  <div class="modal-bg" onclick="closeModal()"><div class="modal" onclick="event.stopPropagation()">
    <div class="modal-title">Thêm case</div>
    <div class="two-col">
      <div><label>ID</label><input type="text" id="f_id" placeholder="hn02-1"/></div>
      <div><label>Sticker</label><input type="text" id="f_sticker" value="🤖"/></div>
    </div>
    <label>Title *</label><input type="text" id="f_title"/>
    <div class="two-col">
      <div><label>Thành phố</label><select id="f_city"><option>Hà Nội</option><option>Hồ Chí Minh</option></select></div>
      <div><label>Owner team</label><input type="text" id="f_owner_team"/></div>
    </div>
    <label>Owner email</label><input type="text" id="f_owner_email"/>
    <label>Mô tả ngắn</label><textarea id="f_short_description" rows="2"></textarea>
    <label>Demo URL</label><input type="text" id="f_demo_url"/>
    <label>Tools (phân cách phẩy)</label><input type="text" id="f_tools"/>
    <div style="display:flex;gap:8px;align-items:center;padding:10px;background:var(--bg3);border-radius:8px;margin-bottom:10px;font-size:11px">
      <label style="display:flex;align-items:center;gap:4px;cursor:pointer;color:var(--teal);margin:0"><input type="radio" name="cs" value="active" checked/> Publish ngay</label>
      <label style="display:flex;align-items:center;gap:4px;cursor:pointer;margin:0"><input type="radio" name="cs" value="draft"/> Draft</label>
    </div>
    <div class="modal-actions">
      <button class="btn" onclick="closeModal()">Hủy</button>
      <button class="btn btn-primary" onclick="doAddCase()">Lưu</button>
    </div>
  </div></div>`;
}

async function doAddCase(){
  const tools=getField("tools").split(",").map(t=>t.trim()).filter(Boolean);
  const isActive=document.querySelector('input[name="cs"]:checked')?.value==="active";
  await upsert("cases",{id:getField("id"),title:getField("title"),city:getField("city")||null,sticker:getField("sticker")||"🤖",owner_email:getField("owner_email"),owner_team:getField("owner_team"),short_description:getField("short_description"),demo_url:getField("demo_url"),tools_used:tools,season_id:state.currentSeason,display_order:state.cases.length+1,is_active:isActive});
}

async function saveMentor(existingId){
  const data={name:getField("name"),role:getField("role"),tag:getField("tag"),avatar_url:getField("avatar_url")||null,display_order:state.mentors.length+1};
  if(!existingId)data.id=getField("id");
  await upsert("mentors",data,existingId||undefined);
}

async function uploadAvatar(){
  const file=document.getElementById("avFile")?.files?.[0];
  if(!file)return;
  try{
    const url=await new Promise((resolve,reject)=>{
      const reader=new FileReader();
      reader.onload=()=>resolve(reader.result);
      reader.onerror=()=>reject(new Error("Không đọc được file"));
      reader.readAsDataURL(file);
    });
    document.getElementById("f_avatar_url").value=url;
    document.getElementById("avPrev").innerHTML=`<img src="${url}" style="width:60px;height:60px;border-radius:50%;object-fit:cover"/>`;
    toast("Ảnh đã sẵn sàng — bấm Lưu để cập nhật");
  }catch(e){toast("Lỗi: "+e.message,"danger");}
}

// Init
loadAll();
</script>
</body>
</html>
