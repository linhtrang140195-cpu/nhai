async function doImportResults(parsed){
  const status=document.querySelector('input[name="ir_s"]:checked')?.value||"announced";
  let n=0;
  for(let i=0;i<parsed.length;i++){
    if(!document.getElementById(`ir_${i}`)?.checked)continue;
    const p=parsed[i];
    await sb("awards",{method:"POST",body:{season_id:state.currentSeason,category_id:p.cat,city:p.city||null,winner_name:p.caseName||p.name,winner_team:p.name,status,votes_count:0},headers:{Prefer:"return=representation"}});
    n++;
  }
  toast(`Đã import ${n} winners!`);closeModal();loadAll();
}

