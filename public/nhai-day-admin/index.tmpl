async function runBackupToSheet(){
  const url=(state.config.backup_sheet_url||"").trim();
  if(!url){toast("Chưa có Apps Script URL — lưu URL trước","danger");return;}
  const statusEl=document.getElementById("backupStatus");
  if(statusEl)statusEl.textContent="⏳ Đang backup...";
  try{
    const payload={
      registrations:state.registrations,
      site_config:Object.entries(state.config).map(([k,v])=>({key:k,value:typeof v==="object"?JSON.stringify(v):String(v)})),
      season_stats:state.seasonStats,
      mentors:state.mentors,
      events:state.events,
      faqs:state.faqs,
      seasons:state.seasons,
      awards:state.awards,
      award_categories:state.awardCats,
      cases:state.cases,
      top_pick_campaigns:state.campaigns,
      top_pick_votes:state.votes
    };
    const res=await fetch(url,{method:"POST",headers:{"Content-Type":"text/plain"},body:JSON.stringify(payload)});
    const result=await res.json();
    if(result.ok){
      toast("Backup thành công! "+result.timestamp);
      if(statusEl)statusEl.textContent="✅ Backup lúc "+new Date(result.timestamp).toLocaleString("vi-VN");
    }else{
      throw new Error(result.error||"Unknown error");
    }
  }catch(err){
    toast("Backup lỗi: "+err.message,"danger");
    if(statusEl)statusEl.textContent="❌ Lỗi: "+err.message;
  }
}

async function importResultsFromSheet(){
  const url=getUrl("results");
  if(!url){toast("Chưa có gid","danger");return;}
  toast("Đang fetch...");
  try{
    const res=await fetch(url);
    if(!res.ok)throw new Error("Fetch failed — đã publish sheet chưa?");
    const rows=parseCSV(await res.text());
    if(rows.length<2){toast("Sheet trống","danger");return;}
    const headers=rows[0];
    const findCol=(kws)=>headers.findIndex(h=>kws.some(k=>h.toLowerCase().includes(k.toLowerCase())));
    const nameCol=findCol(["team","người","tên","nguoi"]);
    const caseCol=findCol(["case","sản phẩm","tóm tắt","tom tat"]);
    const awardCol=findCol(["giải","giai","award","prize"]);
    const parsed=[];let currentCity="";
    for(const row of rows.slice(1)){
      const rt=row.join(" ");
      if(/hà nội|Ha Noi/i.test(rt)&&row.filter(c=>c.trim()).length<4){currentCity="Hà Nội";continue;}
      if(/hồ chí minh|HCM|Ho Chi Minh/i.test(rt)&&row.filter(c=>c.trim()).length<4){currentCity="Hồ Chí Minh";continue;}
      const name=(nameCol>=0?row[nameCol]:row[1])||"";
      const caseName=(caseCol>=0?row[caseCol]:row[4])||"";
      const award=(awardCol>=0?row[awardCol]:row[5])||"";
      if(!name.trim()||!award.trim())continue;
      let cat="";
      let city=currentCity;
      if(/master chef|2[.,]000[.,]000/i.test(award)){
        cat="master-chef";
        if(/hn|hà nội/i.test(award))city="Hà Nội";
        if(/hcm|hồ chí minh/i.test(award))city="Hồ Chí Minh";
      } else if(/early bird|1[.,]000[.,]000/i.test(award))cat="early-bird";
      else if(/500/i.test(award))cat="demo-ready";
      if(!cat)continue;
      parsed.push({name:name.trim(),caseName:caseName.trim(),cat,city,award:award.trim()});
    }
    if(!parsed.length){toast("Không tìm thấy winner — check format sheet","danger");return;}
    showImportResultsModal(parsed);
  }catch(e){toast("Lỗi: "+e.message,"danger");}
}

